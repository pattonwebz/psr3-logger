{
    "name": "pattonwebz/psr3-logger",
    "description": "A PSR-3 compatible logger with a convenience trait for class-level logging.",
    "type": "library",
    "version": "1.0.0",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=7.4",
        "psr/log": "^1.1"
    },
    "autoload": {
        "psr-4": {
            "PattonWebz\\Psr3Logger\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PattonWebz\\Psr3Logger\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "scripts": {
        "test": "phpunit"
    }
}
